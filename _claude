_claude_auth() {
  local -a subcmds
  subcmds=(
    'login:Sign in to your Anthropic account'
    'logout:Log out from your Anthropic account'
    'status:Show authentication status'
    'help:Display help for command'
  )

  case $words[3] in
    login)
      _arguments \
        '(- *)'{-h,--help}'[Display help for command]' \
        '--claudeai[Use Claude subscription (default)]' \
        '--console[Use Anthropic Console (API usage billing)]' \
        '--email[Pre-populate email address on the login page]:email: ' \
        '--sso[Force SSO login flow]'
      ;;
    status)
      _arguments \
        '(- *)'{-h,--help}'[Display help for command]' \
        '(--text)--json[Output as JSON (default)]' \
        '(--json)--text[Output as human-readable text]'
      ;;
    logout)
      _arguments '(- *)'{-h,--help}'[Display help for command]'
      ;;
    *)
      _describe 'auth command' subcmds
      ;;
  esac
}

